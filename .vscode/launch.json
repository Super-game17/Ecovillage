{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch ecovillage (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/ecovillage.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake-build",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}\\vcpkg\\installed\\x64-windows\\bin;${env:PATH}"
                }
            ],
            "console": "integratedTerminal"
        }
    ]
}